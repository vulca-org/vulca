# API Configuration
VITE_API_BASE_URL=http://localhost:8001
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=VULCA
VITE_APP_VERSION=1.0.0

# Environment
VITE_ENVIRONMENT=development
VITE_DEBUG=true

# Supabase Configuration (for newsletter subscriptions and frontend features)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# CDN Configuration (optional, production only)
# VITE_CDN_URL=https://storage.googleapis.com/your-bucket

# Features (optional)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_ERROR_REPORTING=false

# Performance (optional, production only)
# VITE_ENABLE_PWA=false
# VITE_ENABLE_SERVICE_WORKER=false

# Google Services (optional)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
