{
  "schema_version": 1,
  "status": "contract-only",
  "required_output_name": "trace_manifest.json",
  "required_location": "outputs/<thread-id>/presentations/<arm-id>/trace_manifest.json",
  "arm_required_fields": [
    "arm_id",
    "generation_brief",
    "commercial_case",
    "inputs_allowed",
    "inputs_forbidden",
    "runtime_isolation",
    "cache_scope",
    "model_provider",
    "tool_versions",
    "release_decision"
  ],
  "per_slide_required_fields": [
    "slide_id",
    "rhythm_role",
    "source_card_ids",
    "evidence_claim_ids",
    "aesthetic_move_ids",
    "multimodal_record_ids",
    "multimodal_anchor_ids",
    "visual_learning_target_ids",
    "visual_component_ids",
    "video_beat_ids",
    "motion_target_ids",
    "sequence_component_ids",
    "commercial_usecase_id",
    "aesthetic_benchmark_ids",
    "theme_policy_id",
    "typography_system_id",
    "spacing_token_set_id",
    "workflow_decision_ids",
    "source_brand_sanitization",
    "benchmark_validation_probe",
    "theme_validation_probe",
    "visual_repair_policy_ids",
    "visual_delta_from_run2_5",
    "visual_repair_validation_probe",
    "run2_7_usecase_id",
    "run2_7_source_record_ids",
    "run2_7_design_memory_ids",
    "run2_7_workflow_decision_ids",
    "run2_7_delta_from_run2_6r",
    "run2_7_quality_gate",
    "run2_8_decomposition_unit_ids",
    "run2_8_memory_binding_ids",
    "run2_8_gate_matrix_ids",
    "run2_8_code_binding_ids",
    "run2_8_layout_budget",
    "run2_8_visual_delta_from_run2_7",
    "ordered_reveal_steps",
    "asset_ids",
    "density_counts",
    "deleted_or_routed_content",
    "asset_provenance",
    "editability_checks",
    "native_ppt_checks",
    "layout_geometry_checks",
    "structural_qa",
    "aesthetic_qa",
    "repair_actions",
    "release_gate_inputs"
  ],
  "density_count_fields": ["claims", "panels", "visible_words", "proof_objects"],
  "ordered_reveal_step_fields": ["step_id", "order", "reveal_object", "trigger", "duration", "purpose"],
  "native_ppt_check_fields": [
    "native_text_box_count",
    "native_shape_chart_table_diagram_count",
    "raster_asset_count",
    "image_to_native_object_ratio",
    "full_slide_rasterized"
  ],
  "layout_geometry_check_fields": [
    "text_overlap",
    "text_clipping",
    "microtype",
    "default_table_or_chart",
    "repeated_equal_density_grid"
  ],
  "native_ppt_thresholds": {
    "max_image_to_native_object_ratio": 0.5,
    "full_slide_rasterized_allowed": false
  },
  "release_decision_values": ["internal_only", "demo_candidate", "public_blocked", "public_ready"],
  "blocking_rule": "A generated arm cannot be scored or used in public claims when its trace_manifest.json is missing, incomplete, inconsistent with the arm isolation manifest, missing native PPT checks, missing layout geometry checks, or showing full-slide rasterization."
}
