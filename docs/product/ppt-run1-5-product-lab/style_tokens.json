{
  "schema_version": 1,
  "palette": {
    "ink": "#1E1F24",
    "paper": "#F8F7F3",
    "panel": "#FFFFFF",
    "signal": "#0FA36B",
    "warning": "#C94B32",
    "data": "#3767E8",
    "muted": "#68707C"
  },
  "font_stack": [
    "Aptos",
    "Inter",
    "Arial",
    "sans-serif"
  ],
  "spacing": {
    "xs": 6,
    "sm": 12,
    "md": 20,
    "lg": 32,
    "xl": 48
  },
